#!/usr/bin/env bash

# dtcli - Dependency Track CLI
# A command-line interface for Dependency Track REST API

set -euo pipefail

# Configuration
DTCLI_URL="${DTCLI_URL:-http://localhost:8080}"
DTCLI_API_KEY="${DTCLI_API_KEY:-}"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Helper functions
error() {
    echo -e "${RED}Error: $1${NC}" >&2
    exit 1
}

success() {
    echo -e "${GREEN}$1${NC}"
}

warning() {
    echo -e "${YELLOW}$1${NC}"
}

check_config() {
    if [[ -z "$DTCLI_API_KEY" ]]; then
        error "DTCLI_API_KEY environment variable is not set"
    fi
}

api_call() {
    local method="$1"
    local endpoint="$2"
    local extra_curl_opts=()
    if [[ $# -ge 3 ]]; then
        extra_curl_opts=("${@:3}")
    else
        extra_curl_opts=(-H "Content-Type: application/json")
    fi

    local curl_opts=(-s -X "$method" -H "X-Api-Key: $DTCLI_API_KEY")

    curl "${curl_opts[@]}" "${extra_curl_opts[@]}" "${DTCLI_URL}/api/v1${endpoint}"
}

get_project_uuid() {
    local project_name="$1"
    local parent_name="${2:-}"

    local projects
    projects=$(api_call GET "/project")

    local uuid
    if [[ -n "$parent_name" ]]; then
        # Find project with specific name and parent
        uuid=$(echo "$projects" | jq -r --arg name "$project_name" --arg parent "$parent_name" \
            '.[] | select(.name == $name and .parent.name == $parent) | .uuid' | head -n1)
    else
        # Find project by name only
        uuid=$(echo "$projects" | jq -r --arg name "$project_name" \
            '.[] | select(.name == $name) | .uuid' | head -n1)
    fi

    if [[ -z "$uuid" || "$uuid" == "null" ]]; then
        return 1
    fi

    echo "$uuid"
}


cmd_upload() {
    local project_name=""
    local version=""
    local parent_project=""
    local parent_version=""
    local sbom_file=""
    local mark_latest=false

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --project)
                project_name="$2"
                shift 2
                ;;
            --version)
                version="$2"
                shift 2
                ;;
            --parent-project)
                parent_project="$2"
                shift 2
                ;;
            --parent-version)
                parent_version="$2"
                shift 2
                ;;
            --latest)
                mark_latest=true
                shift
                ;;
            *)
                sbom_file="$1"
                shift
                ;;
        esac
    done

    # Validate arguments
    [[ -z "$project_name" ]] && error "Project name is required (--project)"
    [[ -z "$version" ]] && error "Version is required (--version)"
    [[ -z "$sbom_file" ]] && error "SBOM file is required"
    [[ ! -f "$sbom_file" ]] && error "SBOM file not found: $sbom_file"

    check_config

    # Upload SBOM using multipart/form-data
    echo "Uploading SBOM from $sbom_file..."

    local curl_opts=(-F "autoCreate=true")
    curl_opts+=(-F "projectName=$project_name")
    curl_opts+=(-F "projectVersion=$version")

    if [[ -n "$parent_project" ]]; then
        curl_opts+=(-F "parentName=$parent_project")
        [[ -z "$parent_version" ]] && error "Parent version is required when parent project is specified"
        curl_opts+=(-F "parentVersion=$parent_version")
    fi

    if [[ "$mark_latest" == true ]]; then
        curl_opts+=(-F "isLatest=true")
    fi

    curl_opts+=(-F "bom=@$sbom_file")

    local upload_response
    upload_response=$(api_call POST "/bom" "${curl_opts[@]}")

    local token
    token=$(echo "$upload_response" | jq -r '.token')

    if [[ -z "$token" || "$token" == "null" ]]; then
        error "Failed to upload SBOM: $upload_response"
    fi

    success "SBOM uploaded successfully! Token: $token"
}

cmd_has_update() {
    local project_name=""
    local direct_only=false

    while [[ $# -gt 0 ]]; do
        case $1 in
            --project|-project)
                project_name="$2"
                shift 2
                ;;
            --direct-only)
                direct_only=true
                shift
                ;;
            *)
                shift
                ;;
        esac
    done

    [[ -z "$project_name" ]] && error "Project name is required (--project)"
    check_config

    echo "Looking up project: $project_name"
    local project_uuid
    project_uuid=$(get_project_uuid "$project_name") || error "Project not found: $project_name"

    echo "Checking for outdated dependencies..."
    local has_updates=false
    echo ""

    if [[ "$direct_only" == true ]]; then

        # Get dependency graph to identify direct dependencies
        local dependency_graph=""
        echo "Fetching dependency graph..."
        dependency_graph=$(api_call GET "/dependencyGraph/project/$project_uuid/directDependencies")
        echo "=== Direct Dependency Update Status ==="

        # Extract direct component UUIDs
        local direct_uuids
        direct_uuids=$(echo "$dependency_graph" | jq -r '.[].uuid')

        if [[ -z "$direct_uuids" ]]; then
            warning "No direct dependencies found or dependency graph not available"
            return
        fi

        # Filter components to only direct dependencies
        local outdated_components=""
        outdated_components=$(echo "$dependency_graph" | jq -r '.[] | select(.latestVersion != null and .latestVersion != .version) | "\(.name): \(.version) → \(.latestVersion)"')

        if [[ -n "$outdated_components" ]]; then
            has_updates=true
            warning "Outdated dependencies found:"
            echo "$outdated_components"
        else
            success "All dependencies are up to date!"
        fi
    else
        # Get all components
        local components
        components=$(api_call GET "/component/project/$project_uuid")
        echo "=== Dependency Update Status ==="

        local outdated_components
        outdated_components=$(echo "$components" | jq -r '.[] | select(.repositoryMeta.latestVersion != null and .repositoryMeta.latestVersion != .version) | "\(.name): \(.version) → \(.repositoryMeta.latestVersion)"')

        if [[ -n "$outdated_components" ]]; then
            has_updates=true
            warning "Outdated dependencies found:"
            echo "$outdated_components"
        else
            success "All dependencies are up to date!"
        fi
    fi

    echo ""
    if [[ "$has_updates" == true ]]; then
        exit 1
    fi
}

cmd_has_policy_violations() {
    local project_name=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            --project|-project)
                project_name="$2"
                shift 2
                ;;
            *)
                shift
                ;;
        esac
    done

    [[ -z "$project_name" ]] && error "Project name is required (--project)"
    check_config

    echo "Looking up project: $project_name"
    local project_uuid
    project_uuid=$(get_project_uuid "$project_name") || error "Project not found: $project_name"

    echo "Checking for policy violations..."
    local violations
    violations=$(api_call GET "/violation/project/$project_uuid")

    local violation_count
    violation_count=$(echo "$violations" | jq '. | length')

    echo ""
    echo "=== Policy Violations ==="
    echo "Total violations: $violation_count"

    if [[ "$violation_count" -gt 0 ]]; then
        echo ""
        echo "$violations" | jq -r '.[] | "- [\(.type)] \(.policyCondition.policy.name): \(.component.name)@\(.component.version)"'
        echo ""
        error "Policy violations found!"
    else
        success "No policy violations found!"
    fi
}

cmd_help() {
    cat << EOF
dtcli - Dependency Track CLI

Usage: dtcli <command> [options]

Commands:
    upload                     Upload SBOM to Dependency Track
    has-update                 Check for dependency updates
    has-policy-violations      Check for policy violations
    help                       Show this help message

Upload Options:
    --project <name>           Project name (required)
    --version <version>        Project version (required)
    --parent-project <name>    Parent project name (optional)
    --latest                   Mark this version as latest
    <file>                     SBOM file to upload (required)

Check Options:
    --project <name>           Project name (required)
    --direct-only              Check only direct dependencies (has-update only)

Environment Variables:
    DTCLI_URL                  Dependency Track URL (default: http://localhost:8080)
    DTCLI_API_KEY              API key for authentication (required)

Examples:
    dtcli upload --project grafana --version 12.1.1 --parent-project home-lab --latest sbom.json
    dtcli has-update --project grafana
    dtcli has-update --project grafana --direct-only
    dtcli has-policy-violations --project grafana

EOF
}

# Main command dispatcher
main() {
    if [[ $# -eq 0 ]]; then
        cmd_help
        exit 1
    fi

    local command="$1"
    shift

    case "$command" in
        upload)
            cmd_upload "$@"
            ;;
        has-update)
            cmd_has_update "$@"
            ;;
        has-policy-violations)
            cmd_has_policy_violations "$@"
            ;;
        help|--help|-h)
            cmd_help
            ;;
        *)
            error "Unknown command: $command\nRun 'dtcli help' for usage information"
            ;;
    esac
}

main "$@"